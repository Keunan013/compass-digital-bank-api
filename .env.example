# Database
DB_NAME=digital_bank
DB_USERNAME=digital_bank
DB_PASSWORD=digital_bank
DB_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/digital_bank
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# HTTP
SERVER_PORT=8080

# RabbitMQ (transfer notification messaging)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
MESSAGING_ENABLED=true

# JWT
JWT_SECRET=local-development-secret-please-change-me-with-at-least-32-bytes
JWT_EXPIRATION_MINUTES=60
JWT_ISSUER=digital-bank-api

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_TOKENS=60
RATE_LIMIT_REFILL_PERIOD_SECONDS=60

# Demo data seeding
SEED_ENABLED=true
SEED_DEFAULT_PASSWORD=Password123!

# Logging
LOG_LEVEL_APP=INFO
